generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUARIOS ────────────────────────────────────────────────────────────────

model User {
  id        Int       @id @default(autoincrement())
  firstName String
  lastName  String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  phone     String?
  birthDate DateTime?
  gender    String?
  city      String?
  document  String?
  bio       String?
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  orders             Order[]
  cart               Cart?
  waitingList        WaitingList[]
  reviews            Review[]
  refreshTokens      RefreshToken[]
  paymentMethods     PaymentMethod[]
  notificationPrefs  NotificationPreference?
  tickets            Ticket[]
}

// ─── VENUES Y SECCIONES ──────────────────────────────────────────────────────

model Venue {
  id       Int       @id @default(autoincrement())
  name     String
  address  String
  city     String
  country  String    @default("Colombia")
  imageUrl String?

  sections Section[]
  concerts Concert[]
}

model Section {
  id          Int          @id @default(autoincrement())
  name        String
  venueId     Int
  capacity    Int
  description String?
  color       String?

  venue       Venue        @relation(fields: [venueId], references: [id])
  ticketTypes TicketType[]
}

// ─── ARTISTAS ────────────────────────────────────────────────────────────────

model Artist {
  id       Int      @id @default(autoincrement())
  name     String
  bio      String?
  imageUrl String?
  genres   String[]

  concerts Concert[]
}

// ─── CONCIERTOS ──────────────────────────────────────────────────────────────

model Concert {
  id          Int           @id @default(autoincrement())
  artistId    Int
  tourName    String
  description String?
  date        DateTime
  doorsOpenAt DateTime?
  endDate     DateTime?
  venueId     Int
  imageUrl    String?
  bannerUrl   String?
  status      ConcertStatus @default(PUBLISHED)
  isFeatured  Boolean       @default(false)
  genres      String[]
  viewerCount Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  artist      Artist        @relation(fields: [artistId], references: [id])
  venue       Venue         @relation(fields: [venueId], references: [id])
  ticketTypes TicketType[]
  reviews     Review[]
  waitingList WaitingList[]

  @@index([date])
  @@index([artistId])
  @@index([venueId])
  @@index([status])
}

// ─── TIPOS DE BOLETA ─────────────────────────────────────────────────────────

model TicketType {
  id                Int           @id @default(autoincrement())
  concertId         Int
  sectionId         Int?
  name              String
  description       String?
  price             Float
  totalQuantity     Int
  availableQuantity Int
  maxPerOrder       Int           @default(8)

  concert     Concert      @relation(fields: [concertId], references: [id], onDelete: Cascade)
  section     Section?     @relation(fields: [sectionId], references: [id])
  tickets     Ticket[]
  orderItems  OrderItem[]
  cartItems   CartItem[]
  waitingList WaitingList[]

  @@index([concertId])
}

// ─── BOLETAS INDIVIDUALES ─────────────────────────────────────────────────────

model Ticket {
  id           Int          @id @default(autoincrement())
  ticketTypeId Int
  orderId      Int?
  userId       Int?
  row          String?
  seatLabel    String?
  ticketCode   String       @unique
  qrCode       String       @unique
  status       TicketStatus @default(AVAILABLE)
  usedAt       DateTime?
  createdAt    DateTime     @default(now())

  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  order      Order?     @relation(fields: [orderId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])

  @@index([ticketTypeId, status])
  @@index([orderId])
  @@index([userId])
}

// ─── ÓRDENES DE COMPRA ────────────────────────────────────────────────────────

model Order {
  id            Int         @id @default(autoincrement())
  userId        Int
  status        OrderStatus @default(PENDING)
  subtotal      Float
  serviceFee    Float       @default(0)
  insurance     Float       @default(0)
  totalAmount   Float
  paymentMethod String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
  tickets Ticket[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id           Int        @id @default(autoincrement())
  orderId      Int
  ticketTypeId Int
  quantity     Int
  unitPrice    Float

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
}

// ─── CARRITO TEMPORAL ─────────────────────────────────────────────────────────

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique
  expiresAt DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id           Int        @id @default(autoincrement())
  cartId       Int
  ticketTypeId Int
  quantity     Int

  cart       Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@unique([cartId, ticketTypeId])
}

// ─── LISTA DE ESPERA ──────────────────────────────────────────────────────────

model WaitingList {
  id           Int      @id @default(autoincrement())
  userId       Int
  concertId    Int
  ticketTypeId Int
  quantity     Int      @default(1)
  position     Int
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  concert    Concert    @relation(fields: [concertId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@unique([userId, ticketTypeId])
  @@index([ticketTypeId, position])
}

// ─── RESEÑAS ──────────────────────────────────────────────────────────────────

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  concertId Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  concert Concert @relation(fields: [concertId], references: [id], onDelete: Cascade)

  @@unique([userId, concertId])
  @@index([concertId])
}

// ─── MÉTODOS DE PAGO ──────────────────────────────────────────────────────────

model PaymentMethod {
  id          Int      @id @default(autoincrement())
  userId      Int
  lastFour    String
  brand       String
  expiryMonth Int
  expiryYear  Int
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PREFERENCIAS DE NOTIFICACIÓN ────────────────────────────────────────────

model NotificationPreference {
  id                   Int     @id @default(autoincrement())
  userId               Int     @unique
  emailConcertsNearby  Boolean @default(true)
  emailPurchaseConfirm Boolean @default(true)
  emailEventReminders  Boolean @default(true)
  emailOffers          Boolean @default(false)
  pushTicketUpdates    Boolean @default(true)
  pushPriceAlerts      Boolean @default(false)
  smsPurchaseConfirm   Boolean @default(true)
  smsSecurityAlerts    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── REFRESH TOKENS ──────────────────────────────────────────────────────────

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum ConcertStatus {
  DRAFT
  PUBLISHED
  LIVE
  SOLD_OUT
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum TicketStatus {
  AVAILABLE
  RESERVED
  SOLD
  USED
  CANCELLED
}

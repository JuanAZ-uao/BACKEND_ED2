{
  "name": "ticketmaster-backend",
  "version": "1.0.0",
  "description": "Backend API REST para TicketMaster - arquitectura MVC",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:railway": "prisma migrate deploy && node server.js",
    "dev": "nodemon server.js",
    "seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force --skip-seed && npm run seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand tests/unit",
    "test:functional": "jest --runInBand tests/functional",
    "test:api": "node test-api.js",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "ticketmaster",
    "mvc",
    "express",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^13.9.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.1",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.1.3"
  },
  "overrides": {
    "@tootallnate/once": "3.0.1"
  }
}
